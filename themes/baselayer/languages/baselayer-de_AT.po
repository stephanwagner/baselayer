msgstr "Setzt die Permalink-Struktur auf „Beitragsname“ (/%postname%/), sodass URLs wie /kontakt statt ?p=123 verwendet werden."

msgid "Apache (.htaccess)"
msgstr "Apache (.htaccess)"

msgid "Apply recommended rules to .htaccess"
msgstr "Empfohlene Regeln in .htaccess eintragen"

msgid "Writes Expires headers, removes Set-Cookie on static assets, and enables gzip/deflate in the WordPress root .htaccess."
msgstr "Schreibt Expires-Header, entfernt Set-Cookie bei statischen Dateien und aktiviert gzip/deflate in der .htaccess im WordPress-Root."

msgid "Show config"
msgstr "Konfig anzeigen"

msgid "Be careful when editing this. Incorrect rules can break your site or make it inaccessible."
msgstr "Vorsicht beim Bearbeiten: Fehlerhafte Regeln können deine Webseite beschädigen oder unerreichbar machen."

msgid "Nginx"
msgstr "Nginx"

msgid "Recommended snippet for Nginx: add to your server block for gzip, long cache on static assets, and Vary Accept-Encoding. Copy and paste into your Nginx config."
msgstr "Empfohlener Snippet für Nginx: in den Server-Block einfügen für Gzip, langer Cache bei statischen Dateien und Vary Accept-Encoding. In die Nginx-Konfiguration kopieren."

